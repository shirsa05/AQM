# ── AQM Production Environment ──────────────────────────────────────────────
# This file is auto-generated by deploy.py. You should NOT edit it manually.
# Run: python deploy.py --users name1:pass1 name2:pass2 ...
#
# If you need to create this file manually, copy this template to .env
# and fill in real values. NEVER commit .env to git.

# PostgreSQL password (auto-generated by deploy.py)
AQM_DB_PASSWORD=change-me-strong-password

# Per-user login passwords (one per user)
AQM_USER1_PASSWORD=user1-secret-password
AQM_USER2_PASSWORD=user2-secret-password

# Flask session signing keys (one per user — use: python -c "import os; print(os.urandom(24).hex())")
FLASK_SECRET_USER1=change-me-random-hex
FLASK_SECRET_USER2=change-me-random-hex
